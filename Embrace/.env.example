## PocketBase (required for production builds)
# Set this in Vercel/hosting env vars so the live site can talk to your PocketBase instance.
# Example: VITE_PB_URL=https://pb.your-domain.com
# VITE_PB_URL=

VITE_MINERAL_API_KEY=your_goldapi_key_here
VITE_MINERAL_API_BASE_URL=https://www.goldapi.io/api
VITE_ENABLE_PRICE_MOCKS=false
# Optional legacy aliases supported by the app:
# VITE_METALS_API_KEY=your_goldapi_key_here
# VITE_GOLD_API_KEY=your_goldapi_key_here
# For serverless environments (recommended variable names):
# MINERAL_API_KEY=your_goldapi_key_here
# GOLD_API_KEY=your_goldapi_key_here

# Media catalog admin token for POST /api/media
# MEDIA_ADMIN_TOKEN=replace_with_strong_token

# Optional: custom path for media catalog JSON (defaults to data/media-library.json)
# MEDIA_LIBRARY_PATH=data/media-library.json

# Gemini server-side key for classification scripts/API.
# Never expose this as a VITE_ variable.
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash-lite

# Portfolio data source:
# local -> use ALL_IMAGES fallback from src/pages/Portfolio.tsx
# remote -> use listMedia() API/media-library.json
# VITE_PORTFOLIO_MEDIA_SOURCE=local
